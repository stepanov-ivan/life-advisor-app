{
  "rules": [
    {
      "id": "who_protein",
      "type": "range",
      "field": "proteinPercent",
      "params": { "lower": 0.10, "upper": 0.15 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "Белок в норме",
      "description": "ВОЗ: 10–15% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_total_fat",
      "type": "range",
      "field": "fatPercent",
      "params": { "lower": 0.15, "upper": 0.30 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "Жиры в норме",
      "description": "ВОЗ: 15–30% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_saturated_fat",
      "type": "range",
      "field": "saturatedFatPercent",
      "params": { "upper": 0.10 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "Насыщенные жиры",
      "description": "ВОЗ: ≤10% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_trans_fat",
      "type": "range",
      "field": "transFatPercent",
      "params": { "upper": 0.01 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "Трансжиры",
      "description": "ВОЗ: ≤1% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_pufa",
      "type": "range",
      "field": "pufaPercent",
      "params": { "lower": 0.06, "upper": 0.10 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "ПНЖК в норме",
      "description": "ВОЗ: 6–10% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_carbs",
      "type": "range",
      "field": "carbsPercent",
      "params": { "lower": 0.45, "upper": 0.75 },
      "warningRatio": 0.85,
      "category": "macronutrient_balance",
      "title": "Углеводы в норме",
      "description": "ВОЗ: 45–75% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_free_sugar",
      "type": "range",
      "field": "sugarPercent",
      "params": { "upper": 0.10 },
      "warningRatio": 0.85,
      "category": "restrictions",
      "title": "Свободный сахар",
      "description": "ВОЗ: ≤10% суточной энергии",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_sodium",
      "type": "range",
      "field": "sodiumMg",
      "params": { "upper": 2000 },
      "warningRatio": 0.85,
      "category": "restrictions",
      "title": "Соль (натрий)",
      "description": "ВОЗ: ≤2000 мг натрия в день",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_energy_balance",
      "type": "range",
      "field": "energyBalancePercent",
      "params": { "upper": 0.15 },
      "warningRatio": 0.85,
      "category": "restrictions",
      "title": "Энергобаланс",
      "description": "Превышение целевой калорийности",
      "window": "week",
      "minDaysData": 3
    },
    {
      "id": "who_fiber",
      "type": "range",
      "field": "fiberGrams",
      "params": { "lower": 25 },
      "warningRatio": 0.85,
      "category": "restrictions",
      "title": "Клетчатка",
      "description": "ВОЗ: ≥25 г клетчатки в день",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_fruits_vegetables",
      "type": "range",
      "field": "fruitVegGrams",
      "params": { "lower": 400 },
      "warningRatio": 0.85,
      "category": "food_quality",
      "title": "Овощи и фрукты",
      "description": "ВОЗ: ≥400 г овощей и фруктов в день",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_whole_grain",
      "type": "presence",
      "field": null,
      "params": { "category": "whole_grain" },
      "warningRatio": 0.85,
      "category": "food_quality",
      "title": "Цельные злаки",
      "description": "Включайте цельные злаки ежедневно",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_legumes_nuts",
      "type": "presence",
      "field": null,
      "params": { "category": "legume_or_nut" },
      "warningRatio": 0.85,
      "category": "food_quality",
      "title": "Бобовые/орехи/семена",
      "description": "Включайте бобовые, орехи или семена ежедневно",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_red_meat",
      "type": "range",
      "field": "redMeatGrams",
      "params": { "upper": 500 },
      "warningRatio": 0.85,
      "category": "food_quality",
      "title": "Красное мясо",
      "description": "ВОЗ: ≤500 г красного мяса в неделю",
      "window": "week",
      "minDaysData": 3
    },
    {
      "id": "who_processed_meat",
      "type": "presence",
      "field": null,
      "params": { "category": "processed_meat", "inverse": true },
      "warningRatio": 0.85,
      "category": "food_quality",
      "title": "Обработанное мясо",
      "description": "Избегайте обработанного мяса",
      "window": "day",
      "minDaysData": 3
    },
    {
      "id": "who_meal_regularity",
      "type": "countSkipped",
      "field": null,
      "params": { "warningThreshold": 1, "violationThreshold": 4 },
      "warningRatio": 1.0,
      "category": "eating_pattern",
      "title": "Регулярность приёмов",
      "description": "Не пропускайте приёмы пищи",
      "window": "week",
      "minDaysData": 3
    }
  ]
}
